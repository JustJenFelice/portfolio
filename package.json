{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "description": "Personal portfolio site for Jennifer Culp.",
  "license": "MIT",
  "author": "Jennifer Culp <jen@jenculp.dev>",
  "scripts": {
    "format": "prettier --write \"**/*.{html,css,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{html,css,js,json,md}\"",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:html": "htmlhint \"**/*.html\"",
    "check": "npm run format:check && npm run lint:css && npm run lint:html",
    "serve": "serve ."
  },
  "devDependencies": {
    "htmlhint": "^1.1.4",
    "prettier": "^3.3.3",
    "serve": "^14.2.4",
    "stylelint": "^16.9.0",
    "stylelint-config-standard": "^36.0.1"
  }
}
